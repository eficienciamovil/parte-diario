generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Usuario {
  id           Int          @id @default(autoincrement())
  nombre       String
  usuario      String       @unique
  passwordHash String
  rol          String       @default("UNIDAD")
  dependenciaId Int?
  dependencia  Dependencia? @relation(fields: [dependenciaId], references: [id])
  createdAt    DateTime     @default(now())
}

model Dependencia {
  id           Int      @id @default(autoincrement())
  codigo       String   @unique
  nombre       String
  areaSuperior String?
  responsable  String?
  activa       Boolean  @default(true)
  createdAt    DateTime @default(now())

  personal Personal[]
  partes   ParteDiario[]
  usuarios Usuario[]
}

model Personal {
  id             Int         @id @default(autoincrement())
  nro            Int?
  apellidoNombre String
  dni            String?
  grado          String
  especialidad   String?
  cargo          String?
  estado         String      @default("Activo")
  dependenciaId  Int
  dependencia    Dependencia @relation(fields: [dependenciaId], references: [id])
  createdAt      DateTime    @default(now())

  detalles DetalleAsistencia[]
}

model ParteDiario {
  id               Int               @id @default(autoincrement())
  codigo           String            @unique
  fecha            DateTime
  dependenciaId    Int
  dependencia      Dependencia       @relation(fields: [dependenciaId], references: [id])
  responsableCarga String?
  estado           String            @default("Borrador")
  observaciones    String?
  firmadoPor       String?
  fechaCierre      DateTime?
  consolidadoId    Int?
  consolidado      ParteConsolidado? @relation(fields: [consolidadoId], references: [id])
  createdAt        DateTime          @default(now())

  detalles DetalleAsistencia[]
}

model DetalleAsistencia {
  id          Int            @id @default(autoincrement())
  parteId     Int
  parte       ParteDiario    @relation(fields: [parteId], references: [id], onDelete: Cascade)
  personalId  Int
  personal    Personal       @relation(fields: [personalId], references: [id])
  situacion   String         @default("Presente")
  causaId     Int?
  causa       CausaAusencia? @relation(fields: [causaId], references: [id])
  observacion String?
  justificado Boolean        @default(false)

  @@unique([parteId, personalId])
}

model CausaAusencia {
  id                  Int      @id @default(autoincrement())
  codigo              String   @unique
  causa               String
  computaComoAusente  Boolean  @default(true)
  requiereObservacion Boolean  @default(false)
  activa              Boolean  @default(true)

  detalles DetalleAsistencia[]
}

model ParteConsolidado {
  id        Int           @id @default(autoincrement())
  codigo    String        @unique
  fecha     DateTime
  estado    String        @default("Generado")
  partes    ParteDiario[]
  createdAt DateTime      @default(now())
}
